# =============================================================================
# CORTEX Environment Configuration
# =============================================================================
# Copy to .env and fill in your values:
#   cp .env.example .env
# =============================================================================


# -----------------------------------------------------------------------------
# Primary provider — HuggingFace Router (OpenAI-compatible)
# -----------------------------------------------------------------------------
# Cortex routes chat completions through HF Router. Get a token with
# "Inference Providers" permission at https://huggingface.co/settings/tokens
#
HF_TOKEN=hf_your-token-here
HF_MODEL_ID=moonshotai/Kimi-K2.6:together
HF_BASE_URL=https://router.huggingface.co/v1

# Mirror into OPENAI_* so the OpenAI shim picks it up
CORTEX_USE_OPENAI=1
OPENAI_API_KEY=hf_your-token-here
OPENAI_BASE_URL=https://router.huggingface.co/v1
OPENAI_MODEL=moonshotai/Kimi-K2.6:together


# -----------------------------------------------------------------------------
# Multi-tier fallback chain
# -----------------------------------------------------------------------------
# Cortex automatically falls back when the primary model returns
# 401 / 403 / 429 / 5xx errors. Chain order:
#
#   1. HF primary          (HF_MODEL_ID)
#   2. HF fallback list    (HF_MODEL_FALLBACK — comma-separated)
#   3. NVIDIA              (NVIDIA_API_KEY + NVIDIA_MODEL_ID)
#   4. Groq                (GROQ_API_KEY + CORTEX_GROQ_FALLBACK_MODEL)
#   5. Ollama (local)      (CORTEX_OLLAMA_FALLBACK_MODEL)
#
# Each step logs a colored status banner to the terminal:
#   ✗ HF primary failed  │ Kimi-K2.6  (HTTP 403)
#   ↻ trying fallback    │ HF → GLM-5:together
#   ✓ using HF fallback  │ GLM-5:together

# HF fallback models (tried in order after primary fails)
HF_MODEL_FALLBACK=zai-org/GLM-5:together,zai-org/GLM-5:novita

# NVIDIA fallback — GLM-5.1 with thinking. Get key at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_MODEL_ID=z-ai/glm-5.1
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Groq fallback — fast cloud, free tier. Get key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-key-here
CORTEX_GROQ_FALLBACK_MODEL=openai/gpt-oss-120b
CORTEX_GROQ_FALLBACK_URL=https://api.groq.com/openai/v1

# Ollama final fallback — local, works offline. Install from https://ollama.com
# Pull the model first:  ollama pull llama3.2:3b
CORTEX_OLLAMA_FALLBACK_MODEL=llama3.2:3b
CORTEX_OLLAMA_FALLBACK_URL=http://localhost:11434/v1


# -----------------------------------------------------------------------------
# Dual-model mode (optional — planner + executor)
# -----------------------------------------------------------------------------
# When enabled, Cortex picks a different model depending on whether the
# request contains tool_use blocks:
#   - Planner  (reasoning / no tools)  → CORTEX_PLANNER_MODEL
#   - Executor (tool calls / code-gen) → CORTEX_EXECUTOR_MODEL
#
# CORTEX_DUAL_MODEL=1
# CORTEX_PLANNER_MODEL=zai-org/GLM-5:together
# CORTEX_EXECUTOR_MODEL=MiniMaxAI/MiniMax-M2:novita


# -----------------------------------------------------------------------------
# Emotion layer (tone-aware responses)
# -----------------------------------------------------------------------------
# Detects user emotion (frustrated / confused / urgent / happy / ...) from
# the latest message and prepends a tone hint so the LLM replies like a human.
#
# CORTEX_EMOTION_LAYER=1         # local heuristic  (~0.1ms, zero cost)
# CORTEX_EMOTION_LAYER=hf        # HF classifier    (~200ms/turn)
# CORTEX_EMOTION_MODEL=j-hartmann/emotion-english-distilroberta-base
# CORTEX_EMOTION_DEBUG=1         # log detected emotion to stderr


# -----------------------------------------------------------------------------
# Firecrawl scraping (bypass website protections)
# -----------------------------------------------------------------------------
# When set, WebFetch uses Firecrawl to bypass anti-bot / JS rendering.
# Get key at https://firecrawl.dev (paid service).
#
# FIRECRAWL_API_KEY=fc-your-key-here


# -----------------------------------------------------------------------------
# Misc tuning
# -----------------------------------------------------------------------------
# CORTEX_MAX_RETRIES=10                 # max API retries on failure
# CORTEX_UNATTENDED_RETRY=1             # retry 429/529 forever (CI mode)
# CORTEX_DISABLE_CO_AUTHORED_BY=1       # strip "Co-authored-by" from commits
# API_TIMEOUT_MS=60000                  # custom request timeout
# CLAUDE_DEBUG=1                        # verbose debug logs

# Disable Chrome integration (avoids 127.0.0.1 connection errors)
DISABLE_CORTEX_IN_CHROME=1
CORTEX_DISABLE_CHROME=1

# Allow `open` command (Finder, Safari, etc.)
CORTEX_ALLOW_OPEN=1


# =============================================================================
# MCP SERVER CREDENTIALS (for .mcp.json)
# =============================================================================
# Only set tokens for the MCPs you actually use. Missing tokens cause that
# one MCP to fail to start; Cortex keeps working with the rest.

# GitHub MCP — scopes: repo, workflow, user
# GITHUB_TOKEN=ghp_your-token-here

# Postgres MCP
# POSTGRES_CONNECTION_STRING=postgresql://user:password@host:5432/db

# Slack MCP
# SLACK_BOT_TOKEN=xoxb-your-token-here
# SLACK_TEAM_ID=T01234567

# Linear MCP
# LINEAR_API_KEY=lin_api_your-key-here

# Exa MCP
# EXA_API_KEY=your-exa-key-here

# Tavily MCP
# TAVILY_API_KEY=tvly-your-key-here

# MCPs that need NO config (work out of the box):
#   filesystem, puppeteer, fetch, memory, sequential-thinking, sqlite,
#   context7, serena, playwright, git, duckduckgo, time, everything
